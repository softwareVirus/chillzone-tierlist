# PostgreSQL (required). Example local URL:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/chillzone_tierlist?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chillzone_tierlist"

# Local dev: on server start (and first sign-in), `prisma migrate deploy` runs automatically unless CHILLZONE_SKIP_AUTO_MIGRATE=1.
# Vercel: migrations run at build (`build:vercel` in vercel.json). Add DATABASE_URL to Project → Environment Variables for Production + Preview.
# If cwd is wrong, set: CHILLZONE_PROJECT_ROOT=C:\path\to\chillzone-tierlist
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# First-time setup: when the database has no users, the server creates one tenant + this admin on startup (and on first sign-in).
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-8-chars-min"
# Optional defaults:
# TENANT_NAME="Chillzone Tierlist"
# TENANT_SLUG="chillzone"
