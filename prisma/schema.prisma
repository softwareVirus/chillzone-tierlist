generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  createdAt    DateTime      @default(now())
  users        User[]
  participants Participant[]
  tierlistDays TierlistDay[]
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  name             String?
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lastTierlistDate String?
  createdAt        DateTime @default(now())

  @@index([tenantId])
}

model Participant {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  picture   String
  createdAt DateTime     @default(now())
  placements Placement[]

  @@index([tenantId])
}

model TierlistDay {
  id                 String      @id @default(cuid())
  tenantId           String
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date               String
  tierlistScreenshot String?
  placements         Placement[]

  @@unique([tenantId, date])
  @@index([tenantId])
}

model Placement {
  id            String      @id @default(cuid())
  tierlistDayId String
  day           TierlistDay @relation(fields: [tierlistDayId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  tier          String

  @@unique([tierlistDayId, participantId])
  @@index([participantId])
}
